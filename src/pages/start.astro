---
import BaseLayout from '../layouts/BaseLayout.astro';
import StartPage from '../components/start/StartPage';
---

<BaseLayout
  title="Orbits — Get Started"
  description="Tell Bit what you need. Watch it get handled."
  canonicalUrl="https://tryorbits.com/start"
  noIndex={true}
>
  <StartPage client:only="react" />
</BaseLayout>

<style is:global>
  /* The /start demo is intentionally all-Nunito — override the site's serif h1/h2 within it. */
  #start-demo,
  #start-demo :is(h1, h2, h3, h4, h5, h6),
  [role="dialog"] :is(h1, h2, h3, h4, h5, h6) {
    font-family: var(--font-sans);
  }
  /* Nunito Semibold as the base weight across the demo (bold headings still win). */
  #start-demo,
  [role="dialog"] {
    font-weight: 600;
  }
  /* Form controls use shadcn defaults (text-sm / font-medium) — make them bigger + semibold. */
  #start-demo label,
  [role="dialog"] label {
    font-size: 1.0625rem;
    font-weight: 600;
  }
  #start-demo :is(input, textarea, [role="combobox"]),
  [role="dialog"] :is(input, textarea, [role="combobox"]) {
    font-size: 1.125rem;
  }
  /* Keep native controls (date/time pickers) in light mode with a brand accent,
     regardless of the user's OS dark-mode preference. */
  #start-demo,
  [role="dialog"],
  [role="listbox"] {
    color-scheme: light;
  }
  #start-demo input,
  [role="dialog"] input {
    accent-color: hsl(97 17% 42%);
  }
  /* Native date/time inputs left-align value + picker icon; pin the icon to the right edge. */
  #start-demo :is(input[type="date"], input[type="time"]),
  [role="dialog"] :is(input[type="date"], input[type="time"]) {
    position: relative;
  }
  #start-demo input::-webkit-calendar-picker-indicator,
  [role="dialog"] input::-webkit-calendar-picker-indicator {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.6;
    cursor: pointer;
  }
</style>
