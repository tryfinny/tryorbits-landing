---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BlogCTA } from '../../components/blog/BlogCTA';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const canonicalUrl = `https://tryorbits.com/blog/${post.slug}`;
const ogImage = `https://tryorbits.com/og/${post.slug}.png`;
const publishedTime = post.data.date.toISOString();

// Reading time: ~200 words per minute
const wordCount = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": publishedTime,
  "dateModified": publishedTime,
  "url": canonicalUrl,
  "image": ogImage,
  "author": {
    "@type": "Organization",
    "name": "Orbits",
    "url": "https://tryorbits.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Orbits",
    "url": "https://tryorbits.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://tryorbits.com/favicon-96x96.png"
    }
  },
  "keywords": post.data.tags?.join(', '),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
};
---

<BaseLayout
  title={`${post.data.title} | Orbits Blog`}
  description={post.data.description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedTime={publishedTime}
  tags={post.data.tags}
  articleJsonLd={articleJsonLd}
>
  <div class="min-h-screen bg-background">
    <header class="sticky top-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border">
      <div class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
          <img src="/favicon.svg" alt="Orbits" width="48" height="48" />
          <span class="font-serif font-medium text-foreground text-3xl">Orbits</span>
        </a>
        <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          ← All posts
        </a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-16 lg:py-24">
      <div class="mb-10">
        <div class="flex items-center gap-3 text-sm text-muted-foreground">
          <time datetime={publishedTime}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>·</span>
          <span>{readingTime} min read</span>
        </div>
        <h1 class="text-3xl lg:text-4xl xl:text-5xl font-serif font-medium tracking-tight mt-3 mb-4 leading-tight">
          {post.data.title}
        </h1>
        <p class="text-lg text-muted-foreground">{post.data.description}</p>
        {post.data.tags && (
          <div class="flex flex-wrap gap-2 mt-5">
            {post.data.tags.map((tag) => (
              <span class="text-xs px-3 py-1 bg-secondary rounded-full text-muted-foreground">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <hr class="border-border mb-10" />

      <article class="prose prose-lg max-w-none
        prose-headings:font-serif prose-headings:font-medium prose-headings:tracking-tight
        prose-p:text-foreground/80 prose-p:leading-relaxed
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-foreground
        prose-li:text-foreground/80
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3">
        <Content />
      </article>

      <BlogCTA client:only="react" />
    </main>

    {relatedPosts.length > 0 && (
      <section class="border-t border-border mt-8 py-16 px-6">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-sm uppercase tracking-widest text-muted-foreground font-medium mb-8">More from Orbits</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((p) => (
              <a href={`/blog/${p.slug}`} class="group block border border-border rounded-xl p-5 hover:border-primary/30 transition-colors">
                <time class="text-xs text-muted-foreground">
                  {p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <h3 class="font-serif font-medium mt-2 leading-snug group-hover:text-primary transition-colors">
                  {p.data.title}
                </h3>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <footer class="border-t border-border py-8 px-6">
      <div class="max-w-4xl mx-auto text-center text-sm text-muted-foreground">
        © 2026 Orbits. All rights reserved.
      </div>
    </footer>
  </div>
</BaseLayout>
