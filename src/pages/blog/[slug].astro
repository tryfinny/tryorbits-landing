---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BlogCTA } from '../../components/blog/BlogCTA';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const canonicalUrl = `https://tryorbits.com/blog/${post.slug}`;
const publishedTime = post.data.date.toISOString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": publishedTime,
  "url": canonicalUrl,
  "image": "https://tryorbits.com/banner.jpg",
  "author": {
    "@type": "Organization",
    "name": "Orbits",
    "url": "https://tryorbits.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Orbits",
    "url": "https://tryorbits.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://tryorbits.com/favicon-96x96.png"
    }
  },
  "keywords": post.data.tags?.join(', '),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
};
---

<BaseLayout
  title={`${post.data.title} | Orbits Blog`}
  description={post.data.description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  publishedTime={publishedTime}
  tags={post.data.tags}
  articleJsonLd={articleJsonLd}
>
  <div class="min-h-screen bg-background">
    <header class="sticky top-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border">
      <div class="max-w-4xl mx-auto px-6 py-4">
        <a href="/blog" class="inline-flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors text-sm">
          ← All posts
        </a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-16 lg:py-24">
      <div class="mb-10">
        <time class="text-sm text-muted-foreground" datetime={publishedTime}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="text-3xl lg:text-4xl xl:text-5xl font-serif font-medium tracking-tight mt-3 mb-4 leading-tight">
          {post.data.title}
        </h1>
        <p class="text-lg text-muted-foreground">{post.data.description}</p>
        {post.data.tags && (
          <div class="flex flex-wrap gap-2 mt-5">
            {post.data.tags.map((tag) => (
              <span class="text-xs px-3 py-1 bg-secondary rounded-full text-muted-foreground">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <hr class="border-border mb-10" />

      <article class="prose prose-lg max-w-none
        prose-headings:font-serif prose-headings:font-medium prose-headings:tracking-tight
        prose-p:text-foreground/80 prose-p:leading-relaxed
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-foreground
        prose-li:text-foreground/80
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3">
        <Content />
      </article>

      <BlogCTA client:only="react" />
    </main>

    <footer class="border-t border-border py-8 px-6 mt-8">
      <div class="max-w-4xl mx-auto text-center text-sm text-muted-foreground">
        © 2026 Orbits. All rights reserved.
      </div>
    </footer>
  </div>
</BaseLayout>
