---
import '../index.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  // Article-specific SEO
  ogType?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
  articleJsonLd?: object;
}

const {
  title = 'Orbits - Your Household Assistant',
  description = "Orbits manages your home so you don't have to.",
  ogImage = 'https://tryorbits.com/banner.jpg',
  canonicalUrl = 'https://tryorbits.com',
  ogType = 'website',
  publishedTime,
  tags,
  articleJsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Orbits" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:url" content={canonicalUrl} />

    <meta name="application-name" content="Orbits" />
    <meta name="apple-mobile-web-app-title" content="Orbits" />
    <meta name="theme-color" content="#111111" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Orbits Blog" href="https://tryorbits.com/rss.xml" />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}


    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Orbits",
      "url": "https://tryorbits.com",
      "description": "Orbits manages your home so you don't have to.",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "iOS, Android",
      "image": "https://tryorbits.com/banner.jpg",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />

    {articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />}

    <!-- Hash redirect: #tos → /tos, #privacy → /privacy -->
    <script is:inline>
      (function() {
        var hash = window.location.hash;
        if (hash === '#tos') window.location.replace('/tos');
        else if (hash === '#privacy') window.location.replace('/privacy');
      })();
    </script>
  </head>
  <body>
    <slot />
    <!-- Google tag (gtag.js) — loaded after page content for better LCP -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-998792GX0C"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-998792GX0C');
    </script>
  </body>
</html>
